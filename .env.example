# === Email Configuration for The Green Life ===
# Copy this file to .env and fill in your actual credentials.
#
# Có 2 cách gửi email:
#   A) Brevo API (khuyên dùng) — HTTPS, không bị Render chặn, free 300 emails/ngày
#   B) SMTP (Gmail) — bị chặn trên Render free tier, chỉ dùng khi host hỗ trợ SMTP
#
# Brevo:  đăng ký tại https://www.brevo.com → Settings → API Keys
# Gmail:  bật 2FA → tạo App Password tại https://myaccount.google.com/apppasswords

# ── A) Brevo API (primary) ──
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── B) SMTP (fallback) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_ENCRYPTION=tls
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_ADDRESS=your-email@gmail.com
SMTP_FROM_NAME=The Green Life
SMTP_TO_ADDRESS=phoquocduyvn@gmail.com
